---
import type { CollectionEntry } from 'astro:content'
import { resolveProduct, getSiteConfig } from '../lib/config'
import BaseLayout from './BaseLayout.astro'
import Byline from '../components/Byline.astro'
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro'
import ProsConsBox from '../components/ProsConsBox.astro'
import AuthorBio from '../components/AuthorBio.astro'
import PrevNext from '../components/PrevNext.astro'
import RelatedArticles from '../components/RelatedArticles.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import SchemaMarkup from '../components/SchemaMarkup.astro'

interface Props {
  article: CollectionEntry<'articles'>
  prev?: { slug: string; title: string } | null
  next?: { slug: string; title: string } | null
}

const { article, prev, next } = Astro.props
const { data } = article
const cfg = getSiteConfig()

const url = new URL(`/${data.slug}/`, Astro.site).href
const heroUrl = `${cfg.images.base_url}/${data.hero_image}`

const productA = data.product_a ? resolveProduct({ id: data.product_a }, data.slug) : null
const productB = data.product_b ? resolveProduct({ id: data.product_b }, data.slug) : null
const imgA = productA?.image.startsWith('http') ? productA.image : productA ? `${cfg.images.base_url}/${productA.image}` : null
const imgB = productB?.image.startsWith('http') ? productB.image : productB ? `${cfg.images.base_url}/${productB.image}` : null
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalUrl={url}
  ogImage={heroUrl}
  ogType="article"
  noindex={data.noindex}
>
  <SchemaMarkup article={article} url={url} slot="head" />

  <article class="article-page">
    <Breadcrumb crumbs={[
      { label: data.category, href: `/${data.category.toLowerCase().replace(/\s+/g, '-')}/` },
      { label: data.hub, href: `/${data.hub}/` },
      { label: data.title },
    ]} />

    <span class="article-eyebrow">{data.hub.replace(/-/g, ' ')}</span>
    <h1>{data.title}</h1>
    <Byline date={data.date} updated={data.updated} />
    {data.disclosure_required && <AffiliateDisclosure />}

    <img src={heroUrl} alt={data.hero_image_alt ?? data.title} class="article-page__hero" width="900" height="500" fetchpriority="high" decoding="async" />

    {(productA || productB) && (
      <div class="comparison-hero">
        {productA && (
          <div class="comparison-hero__side">
            {imgA && <img src={imgA} alt={productA.name} width="200" height="150" loading="lazy" />}
            <strong>{productA.brand} {productA.name}</strong>
            {productA.affiliate_url && <a href={productA.affiliate_url} class="btn btn--outline btn--sm" rel="nofollow sponsored" target="_blank">Check Price</a>}
          </div>
        )}
        <div class="comparison-hero__vs">VS</div>
        {productB && (
          <div class="comparison-hero__side">
            {imgB && <img src={imgB} alt={productB.name} width="200" height="150" loading="lazy" />}
            <strong>{productB.brand} {productB.name}</strong>
            {productB.affiliate_url && <a href={productB.affiliate_url} class="btn btn--outline btn--sm" rel="nofollow sponsored" target="_blank">Check Price</a>}
          </div>
        )}
      </div>
    )}

    <div class="article-page__content"><slot /></div>

    {productA && <ProsConsBox pros={productA.pros} cons={productA.cons} productName={`${productA.brand} ${productA.name}`} />}
    {productB && <ProsConsBox pros={productB.pros} cons={productB.cons} productName={`${productB.brand} ${productB.name}`} />}

    <AuthorBio />
    {data.related_articles.length > 0 && <RelatedArticles slugs={data.related_articles} />}
    <PrevNext prev={prev} next={next} />
  </article>
</BaseLayout>
