---
import { getSiteConfig, getPersona } from '../lib/config'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonicalUrl?: string
  ogImage?: string
  ogType?: 'website' | 'article'
  noindex?: boolean
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  ogType = 'website',
  noindex = false,
} = Astro.props

const cfg = getSiteConfig()
const persona = getPersona()

// GA4_ID env var overrides site.config.yaml — set per-clone in Cloudflare Pages
const ga4Id = import.meta.env.GA4_ID ?? cfg.analytics.ga4_measurement_id
const googleVerification = import.meta.env.GOOGLE_SITE_VERIFICATION
const bingVerification = import.meta.env.BING_SITE_VERIFICATION
// Per-origin storage key — avoids brand coupling across clones
const consentKey = `${cfg.site.domain.replace(/\./g, '_')}_consent`

const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href
const ogImageUrl = ogImage ?? `${cfg.images.base_url}/og-default.jpg`

const cssVars = `
  --color-primary: ${cfg.visual.primary_color};
  --color-accent: ${cfg.visual.accent_color};
  --color-background: ${cfg.visual.background_color};
  --font-headings: '${cfg.visual.font_headings}', Georgia, serif;
  --font-body: '${cfg.visual.font_body}', system-ui, sans-serif;
`.trim()

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={cfg.site.brand_name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href={`https://fonts.googleapis.com/css2?family=${cfg.visual.font_headings.replace(/ /g, '+')}:ital,wght@0,400;0,600;0,700;1,400&family=${cfg.visual.font_body.replace(/ /g, '+')}:wght@400;500;600&display=swap`}
      rel="stylesheet"
    />

    <!-- CSS custom properties from site config -->
    <style set:html={`:root { ${cssVars} }`} />

    <slot name="head" />

    <!-- GA4 with Consent Mode v2 -->
    {ga4Id && (
      <>
        <script
          set:html={`
window.dataLayer=window.dataLayer||[];
function gtag(){dataLayer.push(arguments)}
gtag('consent','default',{analytics_storage:'denied',ad_storage:'denied',wait_for_update:500});
gtag('js',new Date());
gtag('config','${ga4Id}',{anonymize_ip:true});
if(localStorage.getItem('${consentKey}')==='1'){
  gtag('consent','update',{analytics_storage:'granted'});
}
`}
        />
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
      </>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Cookie consent banner -->
    {ga4Id && (
      <div id="cookie-banner" data-key={consentKey} style="display:none;position:fixed;bottom:0;left:0;right:0;background:#1a2e1a;color:#fff;padding:1rem 1.5rem;z-index:9999;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;font-size:.875rem;">
        <p style="margin:0;flex:1 1 auto;">We use cookies to understand how visitors use this site. <a href="/privacy/" style="color:#a3c97a;text-decoration:underline;">Privacy policy</a></p>
        <div style="display:flex;gap:.5rem;flex-shrink:0;">
          <button id="cookie-accept" style="background:#4a7c59;color:#fff;border:none;padding:.5rem 1rem;border-radius:4px;cursor:pointer;font-size:.875rem;">Accept</button>
          <button id="cookie-decline" style="background:transparent;color:#ccc;border:1px solid #555;padding:.5rem 1rem;border-radius:4px;cursor:pointer;font-size:.875rem;">Decline</button>
        </div>
      </div>
    )}
    <script is:inline>
      (function(){
        var banner=document.getElementById('cookie-banner');
        if(!banner)return;
        var key=banner.dataset.key;
        var stored=localStorage.getItem(key);
        if(stored===null)banner.style.display='flex';
        document.getElementById('cookie-accept').addEventListener('click',function(){
          localStorage.setItem(key,'1');
          banner.style.display='none';
          if(typeof gtag==='function')gtag('consent','update',{analytics_storage:'granted'});
        });
        document.getElementById('cookie-decline').addEventListener('click',function(){
          localStorage.setItem(key,'0');
          banner.style.display='none';
        });
      })();
    </script>

    <!-- Affiliate click tracking -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[rel~="sponsored"]')
        if (!link) return
        if (typeof gtag !== 'function') return

        // Derive position from closest ancestor with a data-track attribute,
        // or fall back to a class-name heuristic
        var pos = 'body'
        var el = link
        while (el && el !== document.body) {
          var cls = el.className || ''
          if (cls.indexOf('verdict-box') > -1)      { pos = 'verdict_box'; break }
          if (cls.indexOf('quick-picks') > -1)       { pos = 'quick_picks'; break }
          if (cls.indexOf('product-card') > -1)      { pos = 'product_card'; break }
          if (cls.indexOf('comparison-hero') > -1)   { pos = 'comparison_hero'; break }
          if (cls.indexOf('pros-cons') > -1)         { pos = 'pros_cons'; break }
          el = el.parentElement
        }

        gtag('event', 'affiliate_click', {
          product_name: link.dataset.product || link.textContent.trim().slice(0, 60),
          link_position: pos,
          link_url: link.href
        })
      })
    </script>
  </body>
</html>
