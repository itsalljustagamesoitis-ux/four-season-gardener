---
import type { CollectionEntry } from 'astro:content'
import { resolveProduct, getSiteConfig } from '../lib/config'
import BaseLayout from './BaseLayout.astro'
import Byline from '../components/Byline.astro'
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro'
import ProsConsBox from '../components/ProsConsBox.astro'
import AuthorBio from '../components/AuthorBio.astro'
import PrevNext from '../components/PrevNext.astro'
import RelatedArticles from '../components/RelatedArticles.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import SchemaMarkup from '../components/SchemaMarkup.astro'

interface Props {
  article: CollectionEntry<'articles'>
  prev?: { slug: string; title: string } | null
  next?: { slug: string; title: string } | null
}

const { article, prev, next } = Astro.props
const { data } = article
const cfg = getSiteConfig()

const url = new URL(`/${data.slug}/`, Astro.site).href
const heroUrl = `${cfg.images.base_url}/${data.hero_image}`

const primaryRef = data.products[0]
const primary = primaryRef ? resolveProduct(primaryRef, data.slug) : null
const imageUrl = primary?.image.startsWith('http') ? primary.image : primary ? `${cfg.images.base_url}/${primary.image}` : null
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalUrl={url}
  ogImage={heroUrl}
  ogType="article"
  noindex={data.noindex}
>
  <SchemaMarkup article={article} url={url} slot="head" />

  <article class="article-page">
    <Breadcrumb crumbs={[
      { label: data.category, href: `/${data.category.toLowerCase().replace(/\s+/g, '-')}/` },
      { label: data.hub, href: `/${data.hub}/` },
      { label: data.title },
    ]} />

    <span class="article-eyebrow">{data.hub.replace(/-/g, ' ')}</span>
    <h1>{data.title}</h1>
    <Byline date={data.date} updated={data.updated} />

    {data.disclosure_required && <AffiliateDisclosure />}

    <img
      src={heroUrl}
      alt={data.hero_image_alt ?? data.title}
      class="article-page__hero"
      width="900"
      height="500"
      fetchpriority="high"
      decoding="async"
    />

    {primary && (
      <div class="verdict-box">
        <div class="verdict-box__header">Our Verdict</div>
        <div class="verdict-box__body">
          <div class="verdict-box__product">
            {imageUrl && (
              <img src={imageUrl} alt={primary.name} width="120" height="90" loading="lazy" />
            )}
            <div>
              <strong>{primary.brand} {primary.name}</strong>
              <p style="font-size:0.875rem;color:var(--color-text-muted);margin:0.25rem 0 0.75rem;">{primary.pros[0]}</p>
              {primary.affiliate_url && (
                <a href={primary.affiliate_url} class="btn btn--primary" rel="nofollow sponsored" target="_blank">
                  Check Price
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    )}

    <div class="article-page__content">
      <slot />
    </div>

    {primary && (
      <ProsConsBox
        pros={primary.pros}
        cons={primary.cons}
        productName={`${primary.brand} ${primary.name}`}
      />
    )}

    <AuthorBio />

    <RelatedArticles currentSlug={data.slug} currentHub={data.hub} currentTags={data.tags} />

    <PrevNext prev={prev} next={next} />
  </article>
</BaseLayout>
