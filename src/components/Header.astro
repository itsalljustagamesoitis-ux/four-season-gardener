---
import { getSiteConfig, getNav } from '../lib/config'

const cfg = getSiteConfig()
const nav = getNav()
---

<header class="site-header">
  <div class="container--wide site-header__inner">
    <a href="/" class="site-header__logo" aria-label={cfg.site.brand_name}>
      <img src={cfg.visual.logo_paths?.header_svg ?? '/images/brand/logo-header.svg'} alt={cfg.site.brand_name} class="site-header__logo-img" width="218" height="40" />
    </a>

    <nav aria-label="Main navigation" class="site-header__nav">
      <ul class="site-nav" id="main-nav">
        {nav.categories.map(cat => {
          const hasDropdown = cat.hubs.length > 1
          return (
            <li class={`site-nav__item ${hasDropdown ? 'has-dropdown' : ''}`}>
              <a href={`/${cat.slug}/`} class="site-nav__link">
                {cat.label}
                {hasDropdown && (
                  <svg class="site-nav__chevron" aria-hidden="true" width="12" height="12" viewBox="0 0 12 12">
                    <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
              </a>
              {hasDropdown && (
                <ul class="site-nav__dropdown">
                  {cat.hubs.map(hub => (
                    <li><a href={`/${hub.slug}/`}>{hub.label}</a></li>
                  ))}
                  <li class="site-nav__dropdown-all">
                    <a href={`/${cat.slug}/`}>All {cat.label} →</a>
                  </li>
                </ul>
              )}
            </li>
          )
        })}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href="/search/" class="site-header__search" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.75"/>
          <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement
  const nav = document.getElementById('main-nav')
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true'
    toggle.setAttribute('aria-expanded', String(!open))
    nav?.classList.toggle('is-open', !open)
  })

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.has-dropdown')) {
      document.querySelectorAll('.site-nav__dropdown').forEach(d => {
        (d as HTMLElement).style.display = ''
      })
    }
  })
</script>

<style>
  .site-header__nav { flex: 1; display: flex; justify-content: center; }

  .site-nav {
    display: flex; align-items: center; gap: 0;
    list-style: none; padding: 0; margin: 0;
  }

  .site-nav__item { position: relative; }

  .site-nav__link {
    display: flex; align-items: center; gap: 0.3rem;
    padding: 0 1rem; height: 64px;
    font-weight: 600; font-size: 0.875rem;
    color: var(--color-text); text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .site-nav__link:hover { color: var(--color-primary); }

  .site-nav__chevron { transition: transform 0.2s; flex-shrink: 0; }
  .site-nav__item:hover .site-nav__chevron { transform: rotate(180deg); }

  /* Dropdown */
  .site-nav__dropdown {
    display: none;
    position: absolute; top: 100%; left: 0;
    background: #fff;
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-primary);
    border-radius: 0 0 var(--radius) var(--radius);
    box-shadow: var(--shadow-md);
    list-style: none; padding: 0.5rem 0; margin: 0;
    min-width: 200px; z-index: 200;
  }
  .site-nav__item:hover .site-nav__dropdown { display: block; }

  .site-nav__dropdown li a {
    display: block; padding: 0.55rem 1.25rem;
    font-size: 0.875rem; color: var(--color-text);
    text-decoration: none; transition: background 0.1s, color 0.1s;
  }
  .site-nav__dropdown li a:hover { background: var(--color-surface-alt); color: var(--color-primary); }

  .site-nav__dropdown-all {
    border-top: 1px solid var(--color-border);
    margin-top: 0.25rem; padding-top: 0.25rem;
  }
  .site-nav__dropdown-all a { font-weight: 700; color: var(--color-primary) !important; }

  /* Search + actions */
  .site-header__actions { display: flex; align-items: center; gap: 0.75rem; }
  .site-header__search {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    color: var(--color-text); text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .site-header__search:hover { background: var(--color-surface-alt); color: var(--color-primary); }

  /* Mobile */
  @media (max-width: 900px) {
    .site-header__nav { display: none; }
    .nav-toggle { display: flex; }

    .site-header__nav.is-open {
      display: flex;
      position: fixed; top: 64px; left: 0; right: 0; bottom: 0;
      background: #fff; z-index: 150;
      flex-direction: column; padding: 1rem 1.5rem;
      overflow-y: auto;
      border-top: 2px solid var(--color-primary);
    }
    .site-nav { flex-direction: column; width: 100%; gap: 0; }
    .site-nav__link { height: auto; padding: 0.875rem 0; border-bottom: 1px solid var(--color-border); justify-content: space-between; width: 100%; }
    .site-nav__dropdown { display: block; position: static; box-shadow: none; border: none; border-top: none; padding: 0 0 0 1rem; }
    .site-nav__dropdown li a { padding: 0.5rem 0; border-bottom: 1px solid var(--color-border); }
  }

  @media (min-width: 901px) {
    .nav-toggle { display: none; }
  }
</style>
