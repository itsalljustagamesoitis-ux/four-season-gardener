---
interface Props {
  headline?: string
  subtext?: string
  buttonText?: string
  compact?: boolean
}

const {
  headline = 'Seasonal gardening tips, straight to your inbox',
  subtext = "No fluff — just Wendy's honest takes on what to plant, prune, and buy each season.",
  buttonText = 'Get the tips',
  compact = false,
} = Astro.props
---

<div class={`email-capture ${compact ? 'email-capture--inline' : ''}`}>
  <div>
    {!compact && <h3 class="email-capture__title">{headline}</h3>}
    {!compact && <p class="email-capture__subtitle">{subtext}</p>}
    {compact && <p class="email-capture__title" style="font-size:1rem;">{headline}</p>}
    <form class="email-capture__form" data-form="email-capture" novalidate>
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        autocomplete="email"
        class="email-capture__input"
      />
      <button type="submit" class="btn btn--accent email-capture__btn">
        {buttonText}
      </button>
    </form>
    <p class="email-capture__privacy">No spam. Unsubscribe any time.</p>
  </div>
</div>

<script>
  document.querySelectorAll('[data-form="email-capture"]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const input = (form as HTMLFormElement).querySelector('input[type="email"]') as HTMLInputElement
      const btn = (form as HTMLFormElement).querySelector('button') as HTMLButtonElement
      const email = input?.value?.trim()
      if (!email) return

      const originalText = btn.textContent
      btn.textContent = 'Subscribing…'
      btn.disabled = true

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        })

        if (res.ok) {
          btn.textContent = "You're in!"
          input.value = ''
        } else {
          btn.textContent = 'Try again'
          btn.disabled = false
          setTimeout(() => { btn.textContent = originalText; btn.disabled = false }, 3000)
        }
      } catch {
        btn.textContent = 'Try again'
        btn.disabled = false
        setTimeout(() => { btn.textContent = originalText ?? 'Get the tips'; btn.disabled = false }, 3000)
      }
    })
  })
</script>
