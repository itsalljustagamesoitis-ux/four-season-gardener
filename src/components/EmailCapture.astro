---
interface Props {
  headline?: string
  subtext?: string
  buttonText?: string
  compact?: boolean
}

const {
  headline = 'Seasonal gardening tips, straight to your inbox',
  subtext = 'No fluff — just Maggie\'s honest takes on what to plant, prune, and buy each season.',
  buttonText = 'Get the tips',
  compact = false,
} = Astro.props
---

<div class={`email-capture ${compact ? 'email-capture--compact' : ''}`}>
  <div class="email-capture__inner">
    {!compact && <h3 class="email-capture__headline">{headline}</h3>}
    {!compact && <p class="email-capture__subtext">{subtext}</p>}
    {compact && <p class="email-capture__headline">{headline}</p>}
    <form class="email-capture__form" data-form="email-capture">
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        autocomplete="email"
        class="email-capture__input"
      />
      <button type="submit" class="btn btn--accent email-capture__btn">
        {buttonText}
      </button>
    </form>
    <p class="email-capture__disclaimer">No spam. Unsubscribe any time.</p>
  </div>
</div>

<script>
  document.querySelectorAll('[data-form="email-capture"]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const input = (form as HTMLFormElement).querySelector('input[type="email"]') as HTMLInputElement
      const btn = (form as HTMLFormElement).querySelector('button') as HTMLButtonElement
      if (!input?.value) return
      btn.disabled = true
      btn.textContent = 'Sending...'
      try {
        await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: input.value }),
        })
        btn.textContent = 'You\'re in!'
        input.value = ''
      } catch {
        btn.disabled = false
        btn.textContent = 'Try again'
      }
    })
  })
</script>
