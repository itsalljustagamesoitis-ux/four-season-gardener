---
interface FAQItem {
  question: string
  answer: string
}

interface Props {
  items: FAQItem[]
  heading?: string
}

const { items, heading = 'Frequently Asked Questions' } = Astro.props
---

<section class="faq-section" aria-label="Frequently asked questions">
  <h2>{heading}</h2>
  <div class="faq-list">
    {items.map((item, i) => (
      <details class="faq-item" name="faq">
        <summary class="faq-item__question">
          <span>{item.question}</span>
          <svg class="faq-item__icon" aria-hidden="true" width="20" height="20" viewBox="0 0 20 20">
            <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="faq-item__answer">
          <p set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>
