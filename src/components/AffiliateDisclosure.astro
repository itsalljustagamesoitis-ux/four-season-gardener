---
interface Props {
  compact?: boolean
}
const { compact = false } = Astro.props
---

{compact ? (
  <p class="affiliate-disclosure affiliate-disclosure--compact">
    <em>Disclosure: We earn a small commission from qualifying purchases at no extra cost to you. Product prices and availability may change — check Amazon for current pricing.</em>
  </p>
) : (
  <div class="affiliate-disclosure">
    <span class="affiliate-disclosure__icon">ℹ</span>
    <p>
      <strong>Affiliate disclosure:</strong> Some links on this page are affiliate links.
      If you buy through them we earn a small commission at no extra cost to you.
      This never influences which products we recommend — we only suggest things we'd buy ourselves.
      Product prices and availability are accurate as of the date published and are subject to change.
      Always check Amazon for current pricing before purchasing.
      <a href="/affiliate-disclosure/">Learn more</a>.
    </p>
  </div>
)}
