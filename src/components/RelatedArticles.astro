---
import { getCollection } from 'astro:content'
import { getSiteConfig } from '../lib/config'

interface Props {
  currentSlug: string
  currentHub: string
  currentTags: string[]
}

const { currentSlug, currentHub, currentTags } = Astro.props
const cfg = getSiteConfig()

const all = await getCollection('articles')
const others = all.filter(a => a.data.slug !== currentSlug)

// 2 from the same hub
const sameHub = others
  .filter(a => a.data.hub === currentHub)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2)

// 1 from a different hub with tag overlap (fall back to most recent cross-hub)
const crossHub = others
  .filter(a => a.data.hub !== currentHub)
  .map(a => ({
    article: a,
    overlap: a.data.tags.filter(t => currentTags.includes(t)).length,
  }))
  .sort((a, b) => b.overlap - a.overlap || b.article.data.date.valueOf() - a.article.data.date.valueOf())
  .slice(0, 1)
  .map(x => x.article)

const related = [...sameHub, ...crossHub]
---

{related.length > 0 && (
  <section class="related-articles" aria-label="Related Reviews">
    <h2>Related Reviews</h2>
    <div class="related-articles__grid">
      {related.map(article => (
        <a href={`/${article.data.slug}/`} class="related-articles__card">
          <img
            src={`${cfg.images.base_url}/${article.data.hero_image}`}
            alt={article.data.hero_image_alt ?? article.data.title}
            width="320"
            height="200"
            loading="lazy"
            decoding="async"
          />
          <div class="related-articles__card-body">
            <span class="related-articles__hub">{article.data.hub.replace(/-/g, ' ')}</span>
            <h3>{article.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
