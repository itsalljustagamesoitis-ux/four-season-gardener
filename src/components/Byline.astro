---
import { getSiteConfig, getPersona } from '../lib/config'

interface Props {
  date: Date
  updated?: Date
  authorOverride?: string
}

const { date, updated, authorOverride } = Astro.props
const cfg = getSiteConfig()
const persona = getPersona()

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })

const displayDate = updated ?? date
const isUpdated = !!updated
---

<div class="byline" data-pagefind-ignore>
  <img
    src={persona.photo_byline}
    alt={persona.name_formal}
    class="byline__photo"
    width="40"
    height="40"
    loading="lazy"
  />
  <div class="byline__meta">
    <span class="byline__author">
      By <a href="/about/">{authorOverride ?? persona.name_used}</a>
    </span>
    <span class="byline__date">
      {isUpdated ? 'Updated' : 'Published'} <time datetime={displayDate.toISOString()}>{fmt(displayDate)}</time>
    </span>
  </div>
</div>
