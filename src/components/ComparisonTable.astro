---
import type { ResolvedProduct } from '../lib/config'

interface Props {
  products: ResolvedProduct[]
  attributes?: string[]
}

const { products, attributes = ['price_band', 'pros', 'cons'] } = Astro.props

const attrLabels: Record<string, string> = {
  price_band: 'Price Range',
  pros: 'Top Strength',
  cons: 'Key Weakness',
}

const priceBandLabel: Record<string, string> = {
  budget: '$',
  mid: '$$',
  premium: '$$$',
}
---

<div class="comparison-table-wrap">
  <table class="comparison-table">
    <thead>
      <tr>
        <th scope="col">Product</th>
        {attributes.map(attr => (
          <th scope="col">{attrLabels[attr] ?? attr}</th>
        ))}
        <th scope="col">Buy</th>
      </tr>
    </thead>
    <tbody>
      {products.map(p => (
        <tr>
          <td>
            <strong>{p.name.toLowerCase().startsWith(p.brand.toLowerCase()) ? p.name : `${p.brand} ${p.name}`}</strong>
            {p.role && <span class="comparison-table__badge">{p.role.replace(/_/g, ' ')}</span>}
          </td>
          {attributes.map(attr => (
            <td>
              {attr === 'price_band' && priceBandLabel[p.price_band]}
              {attr === 'pros' && p.pros[0]}
              {attr === 'cons' && p.cons[0]}
            </td>
          ))}
          <td>
            {p.affiliate_url ? (
              <a
                href={p.affiliate_url}
                class="btn btn--outline"
                rel="nofollow sponsored"
                target="_blank"
              >
                Check Price
              </a>
            ) : '—'}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
