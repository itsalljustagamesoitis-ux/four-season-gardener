---
import { getSiteConfig } from '../lib/config'

const cfg = getSiteConfig()
const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="container--wide">
    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-brand__name">{cfg.site.brand_name}</p>
        <p class="footer-brand__tagline">{cfg.site.tagline}</p>
      </div>
      <div class="footer-links">
        <h4>Categories</h4>
        <ul>
          <li><a href="/outdoor-furniture/">Outdoor Furniture</a></li>
          <li><a href="/garden-tools/">Garden Tools</a></li>
          <li><a href="/lawn-mowers/">Lawn Mowers</a></li>
          <li><a href="/raised-beds/">Raised Beds</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>About</h4>
        <ul>
          <li><a href="/about/">About Maggie</a></li>
          <li><a href="/how-we-test/">How We Test</a></li>
          <li><a href="/reviews/">All Reviews</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>Legal</h4>
        <ul>
          <li><a href="/affiliate-disclosure/">Affiliate Disclosure</a></li>
          <li><a href="/privacy-policy/">Privacy Policy</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} {cfg.site.brand_name}. As an Amazon Associate and Awin publisher, we earn from qualifying purchases.</p>
    </div>
  </div>
</footer>
