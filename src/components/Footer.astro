---
import { getSiteConfig } from '../lib/config'

const cfg = getSiteConfig()
const year = new Date().getFullYear()

const cols = [
  {
    heading: 'Categories',
    links: [
      { label: 'Outdoor Furniture', href: '/outdoor-furniture/' },
      { label: 'Garden Tools', href: '/garden-tools/' },
      { label: 'Lawn Mowers', href: '/lawn-mowers/' },
      { label: 'Raised Beds', href: '/raised-beds/' },
    ],
  },
  {
    heading: 'About',
    links: [
      { label: 'About Maggie', href: '/about/' },
      { label: 'How We Test', href: '/how-we-test/' },
      { label: 'All Reviews', href: '/reviews/' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Affiliate Disclosure', href: '/affiliate-disclosure/' },
      { label: 'Privacy Policy', href: '/privacy-policy/' },
      { label: 'Contact', href: '/contact/' },
    ],
  },
]
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <img
          src={cfg.visual.logo_paths.footer_svg}
          alt={cfg.site.brand_name}
          width="160"
          height="36"
          loading="lazy"
        />
        <p>{cfg.site.tagline}</p>
      </div>
      {cols.map(col => (
        <div class="site-footer__col">
          <h3>{col.heading}</h3>
          <ul>
            {col.links.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="site-footer__bottom">
      <p>
        &copy; {year} {cfg.site.brand_name}. As an Amazon Associate and Awin publisher, we earn from qualifying purchases.
      </p>
    </div>
  </div>
</footer>
