---
import { getSiteConfig, getNav, getPersona } from '../lib/config'

const cfg = getSiteConfig()
const nav = getNav()
const persona = getPersona()
const year = new Date().getFullYear()

// Show top-level categories (excluding "All Reviews" utility entry)
const footerCats = nav.categories.filter(c => c.hubs.length > 0)
---

<footer class="site-footer">
  <div class="container--wide">
    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-brand__name">{cfg.site.brand_name}</p>
        <p class="footer-brand__tagline">{cfg.site.tagline}</p>
      </div>
      <div class="footer-links">
        <h4>Browse</h4>
        <ul>
          {footerCats.map(cat => (
            <li><a href={`/${cat.slug}/`}>{cat.label}</a></li>
          ))}
          <li><a href="/reviews/">All Reviews</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>About</h4>
        <ul>
          <li><a href="/about/">About {persona.name_used}</a></li>
          <li><a href="/how-we-test/">How We Test</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>Legal</h4>
        <ul>
          <li><a href="/affiliate-disclosure/">Affiliate Disclosure</a></li>
          <li><a href="/privacy-policy/">Privacy Policy</a></li>
          <li><a href="/terms/">Terms of Use</a></li>
          <li><a href="/disclaimer/">Disclaimer</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} {cfg.site.brand_name}. As an Amazon Associate and Awin publisher, we earn from qualifying purchases.</p>
    </div>
  </div>
</footer>
