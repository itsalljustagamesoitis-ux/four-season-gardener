---
interface Crumb {
  label: string
  href?: string
}

interface Props {
  crumbs: Crumb[]
}

const { crumbs } = Astro.props
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    {crumbs.map((crumb, i) => (
      <li aria-current={i === crumbs.length - 1 ? 'page' : undefined}>
        {crumb.href && i < crumbs.length - 1
          ? <a href={crumb.href}>{crumb.label}</a>
          : crumb.label
        }
      </li>
    ))}
  </ol>
</nav>
