---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getSiteConfig, getNav } from '../lib/config'

const cfg = getSiteConfig()
const nav = getNav()
const cat = nav.categories.find(c => c.slug === 'outdoor-furniture')!
const all = await getCollection('articles')
const articles = all.filter(a => a.data.category === 'Outdoor Furniture')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout
  title={`Outdoor Furniture Reviews — ${cfg.site.brand_name}`}
  description="Tested reviews of garden benches, Adirondack chairs, teak sets, and all-weather outdoor furniture."
>
  <div class="container" style="padding-top:2rem; padding-bottom:4rem;">
    <div class="category-hero">
      <p class="category-hero__label">Category</p>
      <h1 class="category-hero__title">Outdoor Furniture</h1>
      <p class="category-hero__desc">Teak sets, Adirondack chairs, benches, and all-weather pieces that survive a New England winter. Browse by type or see all reviews below.</p>
    </div>

    <div class="hub-grid">
      {cat.hubs.map(hub => (
        <a href={`/${hub.slug}/`} class="hub-card">
          <span class="hub-card__label">{hub.label}</span>
          <span class="hub-card__arrow">→</span>
        </a>
      ))}
    </div>

    {articles.length > 0 && (
      <>
        <h2 style="margin-top:3rem;">All Outdoor Furniture Reviews</h2>
        <div class="article-grid">
          {articles.map(a => (
            <a href={`/${a.data.slug}/`} class="article-card">
              <div style="background:#e8f0e0;height:180px;display:flex;align-items:center;justify-content:center;font-size:2rem;">🪑</div>
              <div class="article-card__body">
                <span class="article-card__type">{a.data.type.replace('_',' ')}</span>
                <h2 class="article-card__title">{a.data.title}</h2>
                <p class="article-card__desc">{a.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</BaseLayout>
