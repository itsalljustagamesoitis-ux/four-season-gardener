---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getSiteConfig } from '../lib/config'

const cfg = getSiteConfig()
const all = await getCollection('articles')
const articles = all.filter(a => a.data.category === 'Garden Tools')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout
  title={`Best Garden Tools — ${cfg.site.brand_name}`}
  description="Honest reviews of pruners, hoes, trowels, and hand tools from a gardener who tests them across real growing seasons."
>
  <div class="container" style="padding-top:2rem; padding-bottom:4rem;">
    <div class="category-hero">
      <p class="category-hero__label">Category</p>
      <h1 class="category-hero__title">Garden Tools</h1>
      <p class="category-hero__desc">Pruners, hoes, trowels, and hand tools — tested across multiple growing seasons in a demanding garden.</p>
    </div>
    {articles.length > 0 ? (
      <div class="article-grid">
        {articles.map(a => (
          <a href={`/${a.data.slug}/`} class="article-card">
            <div style="background:#e8f0e0;height:180px;display:flex;align-items:center;justify-content:center;font-size:2rem;">🌿</div>
            <div class="article-card__body">
              <span class="article-card__type">{a.data.type.replace('_',' ')}</span>
              <h2 class="article-card__title">{a.data.title}</h2>
              <p class="article-card__desc">{a.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="color:var(--color-text-muted);font-style:italic;margin-top:2rem;">Garden tool reviews coming soon.</p>
    )}
  </div>
</BaseLayout>
