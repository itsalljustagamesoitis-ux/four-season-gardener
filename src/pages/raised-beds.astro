---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getSiteConfig } from '../lib/config'

const cfg = getSiteConfig()
const all = await getCollection('articles')
const articles = all.filter(a => a.data.hub === 'raised-beds')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout
  title={`Raised Garden Bed Reviews — ${cfg.site.brand_name}`}
  description="Reviews of cedar, metal, and modular raised garden beds — what lasts and what warps after one winter."
>
  <div class="container" style="padding-top:2rem; padding-bottom:4rem;">
    <div class="category-hero">
      <p class="category-hero__label">Hub</p>
      <h1 class="category-hero__title">Raised Beds</h1>
      <p class="category-hero__desc">Cedar, metal, and Vego beds — tested across real growing seasons.</p>
    </div>

    {articles.length > 0 && (
      <>
        <h2 style="margin-top:3rem;">All Raised Bed Reviews</h2>
        <div class="article-grid">
          {articles.map(a => (
            <a href={`/${a.data.slug}/`} class="article-card">
              <img src={`${cfg.images.base_url}/${a.data.hero_image}`} alt={a.data.title} width="400" height="225" loading="lazy" decoding="async" />
              <div class="article-card__body">
                <span class="article-card__type">{a.data.type.replace('_', ' ')}</span>
                <h2 class="article-card__title">{a.data.title}</h2>
                <p class="article-card__desc">{a.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</BaseLayout>
