{
  "name": "four-season-gardener",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist && node scripts/build-validator.mjs",
    "postbuild": "node scripts/submit-indexnow.mjs",
    "submit-indexnow": "node scripts/submit-indexnow.mjs",
    "validate:asins": "node scripts/validate-asins.mjs",
    "clone:site": "bash scripts/clone-site.sh",
    "update:clones": "bash scripts/update-all-clones.sh",
    "check:health": "node scripts/check-health.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@pagefind/default-ui": "^1.5.2",
    "astro": "^6.1.10",
    "js-yaml": "^4.1.1",
    "pagefind": "^1.5.2",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.3"
  }
}
